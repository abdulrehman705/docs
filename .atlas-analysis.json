  "keyFeatures": [
    "Self-directed investing: accounts, KYC, order execution, fractional shares",
    "Wealth management: managed portfolios, risk assessment, financial planning, auto-invest",
    "ACH funding via Plaid Link integration",
    "Real-time and historical market data (quotes, bars, snapshots)",
    "Webhook event notifications for orders, transfers, and KYC",
    "Sandbox environment with simulated trading and instant order fills",
    "Idempotency support for all financial operations",
    "Structured error codes (BLUM-{STATUS}-{SEQ})"
  ],
  "publicApiSurface": [
    "POST /accounts",
    "GET /investors/{investor_id}",
    "POST /documents",
    "GET /documents/{document_id}",
    "POST /investors/{investor_id}/funding-sources/plaid/link-token",
    "POST /investors/{investor_id}/funding-sources/connect",
    "POST /investors/{investor_id}/deposits",
    "POST /investors/{investor_id}/withdrawals",
    "POST /investors/{investor_id}/orders",
    "GET /investors/{investor_id}/positions",
    "GET /assets/search",
    "GET /assets/{symbol}",
    "GET /market-data/assets/{symbol}/quote",
    "GET /market-data/assets/{symbol}/bars",
    "GET /market-data/assets/{symbol}/snapshot",
    "GET /market-data/markets/{code}/status",
    "GET /market-data/markets/{code}/calendar",
    "POST /webhooks",
    "GET /webhooks",
    "PATCH /webhooks/{webhook_id}",
    "DELETE /webhooks/{webhook_id}"
  ]
}
